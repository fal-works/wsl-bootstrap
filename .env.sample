# WSL2 Development Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: Git Configuration
# ============================================

# Git user information (used for commits)
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your.email@example.com

# ============================================
# REQUIRED: Development Tool Versions
# ============================================

# Haxe compiler version (e.g., "4.3.7")
HAXE_VERSION=4.3.7

# Node.js version (e.g., "24", "26")
NODE_VERSION=24

# ============================================
# OPTIONAL: Ubuntu Mirror Configuration
# ============================================

# Set if you want to use a regional APT mirror
# This speeds up package downloads for users in specific regions
UBUNTU_MIRROR=https://ftp.udx.icscoe.jp/Linux/ubuntu/

# ============================================
# OPTIONAL: Additional Locales
# ============================================

# Set if applications need to render non-English text
# System messages will always be in English (en_US.UTF-8)
# Space-separated and quoted list of additional locales to generate
ADDITIONAL_LOCALES="ja_JP.UTF-8"
